{
  "reload_style_on_change": true,
  "layer": "buttom",
  "position": "left",

  "margin-top": 3,
  "margin-bottom": 0,
  "margin-left": 1,
  "margin-right": 0,
  
  "modules-left": ["clock", "group/misc"],
  "modules-center": ["ext/workspaces"],
  "modules-right": ["tray", "custom/wlogout"],

  "group/misc": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "misc-modules",
      "transition-top-to-bottom": false
    },
    "modules": [
      "custom/seperator"
    ]
  },

  "custom/seperator": {
    "format": "──",
  },

"ext/workspaces": {
	"on-click": "activate",
  "ignore-hidden": false,
  "format": "{icon}",
  "format-icons": {
      "default": "〇",
      "active": "◉"
    }
},

  "tray": {
    "icon-size": 20,
    "spacing": 15,
    "icons": {
      "blueman": "bluetooth"
    }
  },

  "clock": {
    "format": "{:%H\n%M}"
  },
  
  "custom/wlogout": {
    "format": "⏻",
    "tooltip": "Logout menu",
    "on-click": "wlogout",
    "escape": true
  }
}

