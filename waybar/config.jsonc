{
    "layer": "top",
    "position": "left",
    "width": 44,
    "spacing": 0,

    "modules-left": ["niri/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["memory"],

    "niri/workspaces": {
        "format": "{index}"
    },

    "clock": {
        "format": "{:%H\n%M\n───\n%m\n%d}"
    },

    "memory": {
        "interval": 2,
        "format": "RAM\n{used:0.1f}G"
    }
}
