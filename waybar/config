{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "left",
  "output": "DP-2",

  "margin-top": 10,
  "margin-bottom": 10,
  "margin-left": 9,
  "margin-right": 0,
  
  "modules-left": ["clock", "group/misc"],
  "modules-center": ["niri/workspaces"],
  "modules-right": ["group/volume", "tray"],

  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical"
  },
  
  "group/volume": {
    "orientation": "vertical",
    "drawer": {
      "transition-duration": 500,
      "transition-top-to-bottom": true
    },
    "modules": ["pulseaudio", "pulseaudio/slider"]
  },

  "group/misc": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "misc-modules",
      "transition-top-to-bottom": false
    },
    "modules": [
      "custom/seperator"
    ]
  },

  "custom/seperator": {
    "format": "──",
    "on-click": "activate"
  },

"niri/workspaces": {
	"on-click": "activate",
  "format": "{icon}",
  "format-icons": {
      "default": "〇",
      "active": "◉"
    }
},

  "tray": {
    "icon-size": 15,
    "spacing": 10,
    "icons": {
      "blueman": "bluetooth"
    }
  },

  "clock": {
    "format": "{:%H\n%M}"
  }
}
